// Configuração do Cloudflare Worker (proxy da Fase 2, multiusuário).
// SEGREDOS (nunca ficam neste arquivo nem no git):
//   npx wrangler secret put ANTHROPIC_API_KEY   <- chave da API (só o dono digita)
//   npx wrangler secret put APP_TOKEN           <- senha(s) do app: uma por
//     pessoa, separadas por vírgula (ex.: "senha-daniel,senha-maria").
//     Para revogar alguém, regrave o segredo sem a senha da pessoa.
{
  "name": "diario-alimentar-proxy",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  // NUNCA apagar variáveis/segredos criados pelo painel da Cloudflare ao
  // fazer deploy pela linha de comando (foi assim que a chave sumiu uma vez)
  "keep_vars": true,
  "vars": {
    // origens autorizadas a chamar o proxy (CORS)
    "ALLOWED_ORIGINS": "https://azimoov.github.io,http://localhost:8123",
    // modelo de visão; troque se quiser (ex.: claude-sonnet-5 é mais barato)
    "CLAUDE_MODEL": "claude-opus-4-8",
    // fuso p/ contar o dia do limite de fotos
    "TIMEZONE": "America/Sao_Paulo",
    // máx. de fotos analisadas por dia, somando todos os usuários
    "PHOTO_DAILY_LIMIT": "60"
  },
  // contador do limite diário de fotos
  "kv_namespaces": [
    { "binding": "DIARIO_KV", "id": "fb8a5a87a30f4f5fb8010a406495f3a6" }
  ]
}
